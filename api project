            <li class="category-item" data-category="international" data-query="world news">International</li>
            <li class="category-item" data-category="automobile" data-query="automobile news">Automobile</li>
            <li class="category-item" data-category="science" data-query="science news">Science</li>
            <li class="category-item" data-category="travel" data-query="travel news">Travel</li>
            <li class="category-item" data-category="miscellaneous" data-query="general news">Miscellaneous</li>
            <li class="category-item" data-category="fashion" data-query="fashion news">Fashion</li>
